#include <iostream>
#include <vector>
using namespace std;

int main() {
    vector<int> coins = {1, 5, 10, 25, 50};
    vector<long long> dp(7490, 0);

    dp[0] = 1;

    for (int c : coins) {
        for (int i = c; i <= 7489; i++) {
            dp[i] += dp[i - c];
        }
    }

    int n;
    while (cin >> n) {
        cout << dp[n] << endl;
    }

    return 0;
}


